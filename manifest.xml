<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>530C19C2-1770-4B3D-9785-83F54B6AB780</Id>
  <Version>1.7.0.0</Version>
  <ProviderName>IT๙</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="IT๙" />
  <Description DefaultValue="Professional tool to convert Arabic numerals to Thai numerals with Smart Ignore logic." />
  <IconUrl DefaultValue="https://vk-poonyakanok.github.io/thai-numeral-converter/icon.png" />
  <HighResolutionIconUrl DefaultValue="https://vk-poonyakanok.github.io/thai-numeral-converter/icon.png" />
  <SupportUrl DefaultValue="https://github.com/vk-poonyakanok/thai-numeral-converter" />
  <AppDomains>
    <AppDomain>https://vk-poonyakanok.github.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document" />
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://vk-poonyakanok.github.io/thai-numeral-converter/" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title" />
            <Description resid="GetStarted.Description" />
            <LearnMoreUrl resid="GetStarted.LearnMore" />
          </GetStarted>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="Group1">
                <Label resid="Group1.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://vk-poonyakanok.github.io/thai-numeral-converter/icon.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://vk-poonyakanok.github.io/thai-numeral-converter/icon.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://vk-poonyakanok.github.io/thai-numeral-converter/icon.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://vk-poonyakanok.github.io/thai-numeral-converter/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://vk-poonyakanok.github.io/thai-numeral-converter/" />
        <bt:Url id="GetStarted.LearnMore" DefaultValue="https://github.com/vk-poonyakanok/thai-numeral-converter" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="IT๙" />
        <bt:String id="Group1.Label" DefaultValue="IT๙" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="IT๙ Converter" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Convert Arabic numerals to Thai numerals." />
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the IT๙ Converter tool." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
